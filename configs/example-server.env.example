# Multi-DB cron backup: one config per server/DB.
# Copy to configs/<name>.env (e.g. configs/prod-app1.env) and fill in.
# cron-backup-all.sh runs backup for each configs/*.env and pushes to S3.

# Source (this server/DB)
SOURCE_HOST=mysql-server1.example.com
SOURCE_PORT=3306
SOURCE_USER=backup_user
SOURCE_PASSWORD=your_password
SOURCE_DATABASE=your_database

# Local backup path (before S3)
BACKUP_DIR=./backups

# S3 (required for cron backup): path is bucket/YYYYMMDD/upt/db_timestamp.tar.gz (all DBs under upt/)
# Example: s3://upt-database-backup/20260223/upt/mydb_20260223_000001.tar.gz
S3_BUCKET=upt-database-backup
S3_PREFIX=upt
AWS_REGION=us-east-1

# Optional performance
PARALLEL_JOBS=16
COMPRESS=1
CHUNK_SIZE_MB=64
BACKUP_TOOL=mydumper
