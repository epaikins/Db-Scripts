# MySQL Backup/Restore - Config (copy to config.env and fill in)
# Passwords with ( ) $ ` " \ etc are safe; wrap in single quotes if you prefer:
#   SOURCE_PASSWORD='my(pass)word'
# Source (backup from)
SOURCE_HOST=source-mysql.example.com
SOURCE_PORT=3306
SOURCE_USER=backup_user
SOURCE_PASSWORD=your_password
SOURCE_DATABASE=your_database

# Target (restore to)
TARGET_HOST=target-mysql.example.com
TARGET_PORT=3306
TARGET_USER=restore_user
TARGET_PASSWORD=your_password
TARGET_DATABASE=your_database

# Paths
BACKUP_DIR=./backups
# For restore: path to backup dir (local or s3://bucket/prefix/db_timestamp.tar.gz)
# e.g. ./backups/mydb_20250223_120000  or  s3://upt-database-backup/20260223/upt/mydb_20260223_000001.tar.gz
RESTORE_PATH=
# Optional: remote backup path when streaming (e.g. user@target:/backups)
REMOTE_BACKUP_PATH=

# S3 (optional): path is bucket/YYYYMMDD/<folder>/db_timestamp.tar.gz; folder = S3_PREFIX, default "upt"
# Example: s3://upt-database-backup/20260223/upt/mydb_20260223_000001.tar.gz
S3_BUCKET=
S3_PREFIX=upt
AWS_REGION=us-east-1

# Performance (tune for your hardware; more threads = faster but more load)
PARALLEL_JOBS=16
# Restore threads (myloader); if myloader crashes (e.g. Trace/breakpoint trap), try RESTORE_THREADS=1 or 2
RESTORE_THREADS=
COMPRESS=1
CHUNK_SIZE_MB=64

# Tool preference: mydumper (fast) | mysqldump (fallback)
BACKUP_TOOL=mydumper
